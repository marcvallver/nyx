#!/usr/bin/env python3
"""nyx-bubble-capture — hook `Stop` de Claude Code.

Avisa a Nyx de que una sesión de terminal terminó su turno, en COMPACTO:
solo "⌁ sesión <repo>", sin el texto de la respuesta y nunca por voz
(decisión de Marc: la voz y el texto de Nyx son exclusivos de su sesión core).
El daemon filtra los turnos de su propio backend (mismo session_id) y respeta
`terminal_echo.enabled` del config. Si el daemon no corre, no hace nada.
"""

import json
import os
import sys

REPO = os.path.dirname(os.path.dirname(os.path.realpath(__file__)))
sys.path.insert(0, REPO)

from nyx.client import send  # noqa: E402


def _repo_name(payload: dict) -> str:
    cwd = (payload.get("cwd") or "").rstrip("/")
    if cwd:
        return os.path.basename(cwd) or "terminal"
    # fallback: el dir del transcript codifica el cwd munged (-home-marc-Projects-nyx)
    tp = payload.get("transcript_path") or ""
    munged = os.path.basename(os.path.dirname(tp))
    return munged.rsplit("-", 1)[-1] if munged else "terminal"


def main() -> None:
    try:
        payload = json.load(sys.stdin)
    except (json.JSONDecodeError, ValueError):
        return
    if not isinstance(payload, dict):
        return
    send({
        "op": "session_done",
        "repo": _repo_name(payload),
        "session_id": payload.get("session_id") or "",
    })


if __name__ == "__main__":
    main()
