#!/usr/bin/env python3
"""nyx-ctl — control del daemon de Nyx.

  on|start    lanza el daemon (systemd si hay unit; si no, spawn + autostart KDE)
  off|stop    pide al daemon que se cierre (op quit)
  restart     reinicio limpio
  install     instala la unit systemd --user (--notifyd: + activación D-Bus)
  uninstall   retira unit y activación D-Bus
  toggle      alterna el daemon
  status      estado completo (modelo, sesión, mood, voz, coste…)
  tts [on|off] voz: sin arg alterna; on/off fija (persiste en config.json)
  say <texto> muestra un bocadillo
  session     sesión core: show | new (archiva el hilo) | open (kitty + claude --resume)
  notifs [-n N] historial de notificaciones (incl. silenciadas)
  dnd [on|off]  no molestar (las críticas siguen pasando)
  watchers [on|off <nombre>]  capa proactiva: estado y toggles (opt-in)
  panel       alterna el centro de control (átalo a Meta+N)
  config      list | get <ruta> | set <ruta> <valor>  (rutas punteadas, valor JSON)
  reload      relee config.json en el daemon (aplica lo aplicable en vivo)
  logs [-f]   cola del log del daemon
  doctor      diagnóstico del entorno (socket, layer-shell, config, voz, notifs)
  ping        diagnóstico

Lanza el daemon con LD_PRELOAD (imprescindible para gtk4-layer-shell) y
PYTHONPATH al repo, así que funciona estando symlinkado en ~/.local/bin.
"""

import json
import os
import subprocess
import sys

REPO = os.path.dirname(os.path.dirname(os.path.realpath(__file__)))
sys.path.insert(0, REPO)

from nyx import config as nyxconfig  # noqa: E402
from nyx.client import daemon_running, send  # noqa: E402

PRELOAD = "/usr/lib/libgtk4-layer-shell.so"
AUTOSTART = os.path.expanduser("~/.config/autostart/nyx.desktop")
LOG = os.path.expanduser("~/.cache/nyx/daemon.log")
UNIT = os.path.expanduser("~/.config/systemd/user/nyx.service")
DBUS_SERVICE = os.path.expanduser(
    "~/.local/share/dbus-1/services/org.freedesktop.Notifications.service")
APP_ICON = os.path.expanduser(
    "~/.local/share/icons/hicolor/scalable/apps/org.marc.nyx.svg")
DESKTOP_FILE = os.path.expanduser("~/.local/share/applications/org.marc.nyx.desktop")


def unit_installed() -> bool:
    return os.path.exists(UNIT)


def _render_template(name: str) -> str:
    """Lee dist/<name> y sustituye @REPO@ por la ruta real del repo."""
    with open(os.path.join(REPO, "dist", name), encoding="utf-8") as f:
        return f.read().replace("@REPO@", REPO)


def install(notifyd: bool = False) -> None:
    """Instala la unit systemd --user (COPIA real, nunca symlink: systemd no
    atraviesa /home/marc 0700) y reemplaza el autostart .desktop. Con --notifyd,
    instala también la activación D-Bus de org.freedesktop.Notifications."""
    os.makedirs(os.path.dirname(UNIT), exist_ok=True)
    with open(UNIT, "w", encoding="utf-8") as f:
        f.write(_render_template("nyx.service"))
    subprocess.run(["systemctl", "--user", "daemon-reload"], check=False)
    subprocess.run(["systemctl", "--user", "enable", "nyx.service"],
                   check=False, capture_output=True)
    if os.path.exists(AUTOSTART):  # reemplazo, no convivencia (dos lanzadores = carreras)
        os.remove(AUTOSTART)
        print("autostart .desktop retirado (lo sustituye la unit)")
    print(f"unit instalada y habilitada: {UNIT}")
    # icono de app + desktop file (KWin resuelve el icono de las ventanas por app-id)
    os.makedirs(os.path.dirname(APP_ICON), exist_ok=True)
    import shutil as _shutil
    _shutil.copyfile(os.path.join(REPO, "assets", "icons", "org.marc.nyx.svg"), APP_ICON)
    os.makedirs(os.path.dirname(DESKTOP_FILE), exist_ok=True)
    with open(DESKTOP_FILE, "w", encoding="utf-8") as f:
        f.write(_render_template("org.marc.nyx.desktop"))
    subprocess.run(["kbuildsycoca6"], check=False, capture_output=True)  # refresca KDE
    print(f"icono + lanzador instalados: {DESKTOP_FILE}")
    if notifyd:
        os.makedirs(os.path.dirname(DBUS_SERVICE), exist_ok=True)
        with open(DBUS_SERVICE, "w", encoding="utf-8") as f:
            f.write(_render_template("org.freedesktop.Notifications.service"))
        print(f"activación D-Bus del notifyd instalada: {DBUS_SERVICE}")
        print("recuerda: nyx-ctl config set notifications.enabled true (+ takeover)")
    print("arranca con: systemctl --user start nyx  (o nyx-ctl on)")


def uninstall() -> None:
    subprocess.run(["systemctl", "--user", "disable", "--now", "nyx.service"],
                   check=False, capture_output=True)
    for path, label in ((UNIT, "unit"), (DBUS_SERVICE, "activación D-Bus"),
                        (APP_ICON, "icono"), (DESKTOP_FILE, "lanzador")):
        if os.path.exists(path):
            os.remove(path)
            print(f"{label} retirada: {path}")
    subprocess.run(["systemctl", "--user", "daemon-reload"], check=False)
    print("hecho; `nyx-ctl on` vuelve al modo autostart .desktop")


def _write_autostart() -> None:
    os.makedirs(os.path.dirname(AUTOSTART), exist_ok=True)
    with open(AUTOSTART, "w") as f:
        f.write(
            "[Desktop Entry]\n"
            "Type=Application\n"
            "Name=Nyx (asistente Claude)\n"
            f"Exec=env LD_PRELOAD={PRELOAD} PYTHONPATH={REPO} python3 -m nyx\n"
            "X-KDE-autostart-phase=2\n"
            "OnlyShowIn=KDE;\n"
        )


def start() -> None:
    if daemon_running():
        print("nyx: ya en marcha")
        return
    if unit_installed():
        subprocess.run(["systemctl", "--user", "start", "nyx.service"], check=False)
        print("nyx: ON (systemd)")
        return
    os.makedirs(os.path.dirname(LOG), exist_ok=True)
    env = os.environ.copy()
    env["LD_PRELOAD"] = PRELOAD
    env["PYTHONPATH"] = REPO + (os.pathsep + env["PYTHONPATH"] if env.get("PYTHONPATH") else "")
    with open(LOG, "a") as logf:
        subprocess.Popen(
            [sys.executable, "-m", "nyx"],
            cwd=REPO,
            env=env,
            stdout=logf,
            stderr=logf,
            stdin=subprocess.DEVNULL,
            start_new_session=True,
        )
    print("nyx: ON")
    _write_autostart()


def stop() -> None:
    if daemon_running():
        send({"op": "quit"})  # cierre limpio (exit 0 → Restart=on-failure no relanza)
    if not unit_installed() and os.path.exists(AUTOSTART):
        os.remove(AUTOSTART)
    print("nyx: OFF")


def restart() -> None:
    """Reinicio limpio: quit + esperar a que muera + start (sin tocar el autostart)."""
    import time

    if unit_installed():
        subprocess.run(["systemctl", "--user", "restart", "nyx.service"], check=False)
        print("nyx: reiniciado (systemd)")
        return
    if daemon_running():
        send({"op": "quit"})
        for _ in range(50):  # hasta 5 s a que suelte el socket
            time.sleep(0.1)
            if not daemon_running():
                break
        else:
            print("nyx: el daemon no termina; revisa `nyx-ctl logs`", file=sys.stderr)
            return
    start()


def logs(follow: bool = False) -> int:
    if unit_installed():
        cmd = ["journalctl", "--user", "-u", "nyx.service", "-n", "40"]
        cmd += ["-f"] if follow else ["--no-pager"]
    elif os.path.exists(LOG):
        cmd = ["tail", "-n", "40"] + (["-f"] if follow else []) + [LOG]
    else:
        print(f"sin log todavía ({LOG})", file=sys.stderr)
        return 1
    try:
        return subprocess.call(cmd)
    except KeyboardInterrupt:
        return 0


def print_status() -> None:
    resp = send({"op": "status"})
    if not resp:
        print("stopped")
        return
    cost_last = resp.get("cost_last_usd")
    cost_total = resp.get("cost_total_usd")
    print("running" + (" · busy" if resp.get("busy") else ""))
    print(f"  modelo:  {resp.get('model', '?')}")
    print(f"  sesión:  {resp.get('session') or '(nueva)'}")
    print(f"  mood:    {resp.get('mood', '?')}")
    print(f"  voz:     {'ON' if resp.get('tts') else 'off'}"
          f" · stt {'ok' if resp.get('stt_available') else 'no disponible'}")
    print(f"  notifyd: {'activo' if resp.get('notifyd') else 'off'}")
    if resp.get("turns"):
        last = f"${cost_last:.4f}" if isinstance(cost_last, int | float) else "—"
        total = f"${cost_total:.4f}" if isinstance(cost_total, int | float) else "—"
        print(f"  turnos:  {resp['turns']} · último {last} · total {total}")


def doctor() -> int:
    """Diagnóstico del entorno de Nyx. Devuelve 1 si hay algún ✘."""
    import shutil

    checks: list[tuple[bool, str, str]] = []

    def check(ok: bool, label: str, detail: str = "") -> None:
        checks.append((ok, label, detail))

    running = daemon_running()
    check(running, "daemon", "responde al ping" if running else "parado (nyx-ctl on)")
    check(os.path.exists(PRELOAD), "gtk4-layer-shell", PRELOAD)
    gi_ok = subprocess.run(
        [sys.executable, "-c", "import gi; gi.require_version('Gtk', '4.0')"],
        capture_output=True,
    ).returncode == 0
    check(gi_ok, "PyGObject/GTK4", "" if gi_ok else "no importa gi (¿python-gobject?)")
    raw = nyxconfig._read_raw()
    eff = nyxconfig.deep_merge(nyxconfig.DEFAULTS, nyxconfig.migrate(raw)
                               if nyxconfig.is_legacy(raw) else raw)
    warns = nyxconfig.validate(eff)
    check(not warns, "config.json", "; ".join(warns) if warns else "schema v2 válido")
    persona = os.path.expanduser("~/.config/nyx/persona.md")
    settings = os.path.expanduser("~/.config/nyx/settings.json")
    check(os.path.exists(persona), "persona.md", persona)
    check(os.path.exists(settings), "settings.json (perfil aislado)", settings)
    venv_py = os.path.expanduser("~/.local/share/nyx/venv-voice/bin/python")
    check(os.path.exists(venv_py), "venv de voz (STT)", venv_py)
    for binname in ("edge-tts", "ffmpeg", "pw-play"):
        venv_bin = os.path.expanduser(f"~/.local/share/nyx/venv-voice/bin/{binname}")
        found = venv_bin if os.path.exists(venv_bin) else shutil.which(binname)
        check(bool(found), f"voz: {binname}", found or "no encontrado")
    owner = subprocess.run(
        ["gdbus", "call", "--session", "--dest", "org.freedesktop.DBus",
         "--object-path", "/org/freedesktop/DBus",
         "--method", "org.freedesktop.DBus.GetNameOwner",
         "org.freedesktop.Notifications"],
        capture_output=True, text=True,
    )
    check(owner.returncode == 0, "org.freedesktop.Notifications",
          "con dueño (KDE o Nyx)" if owner.returncode == 0 else "sin dueño")
    if unit_installed():
        active = subprocess.run(
            ["systemctl", "--user", "is-active", "nyx.service"],
            capture_output=True, text=True,
        ).stdout.strip()
        check(active == "active", "systemd unit", f"nyx.service {active}")
        exec_ok = REPO in open(UNIT, encoding="utf-8").read()
        check(exec_ok, "unit ↔ repo",
              "ExecStart apunta a este repo" if exec_ok
              else f"ExecStart NO apunta a {REPO} (re-ejecuta nyx-ctl install)")
    else:
        check(os.path.exists(AUTOSTART), "autostart",
              AUTOSTART if os.path.exists(AUTOSTART)
              else "sin autostart ni unit (nyx-ctl on / nyx-ctl install)")
    if os.path.exists(DBUS_SERVICE):
        ok_dbus = REPO in open(DBUS_SERVICE, encoding="utf-8").read()
        check(ok_dbus, "activación D-Bus notifyd",
              "coherente con el repo" if ok_dbus
              else "Exec de otra ruta (re-ejecuta nyx-ctl install --notifyd)")

    bad = 0
    for ok, label, detail in checks:
        mark = "✔" if ok else "✘"
        bad += 0 if ok else 1
        print(f" {mark} {label}" + (f" — {detail}" if detail else ""))
    return 1 if bad else 0


def session_cmd(args: list[str]) -> int:
    """Sesión core de Nyx: show (default) | new | open."""
    import shutil

    sub = args[0] if args else "show"
    if sub == "show":
        resp = send({"op": "status"})
        if not resp:
            print("daemon parado (nyx-ctl on)")
            return 1
        from nyx.chatlog import CHAT_LOG
        turns = 0
        if os.path.exists(CHAT_LOG):
            with open(CHAT_LOG, encoding="utf-8") as f:
                turns = sum(1 for _ in f)
        print(f"sesión core: {resp.get('session') or '(nueva — aún sin turnos)'}")
        print(f"  modelo: {resp.get('model')} · turnos del daemon: {resp.get('turns', 0)}")
        print(f"  hilo persistido: {CHAT_LOG} ({turns} entradas)")
        print("  ver el hilo: nyx-ctl history (Meta+H) · abrir en terminal: "
              "nyx-ctl session open")
        return 0
    if sub == "new":
        resp = send({"op": "session_new"})
        if not resp:
            print("daemon parado (nyx-ctl on)")
            return 1
        arch = resp.get("archived")
        print("sesión core nueva" + (f" (hilo anterior en {arch})" if arch else ""))
        return 0
    if sub == "open":
        resp = send({"op": "status"})
        sid = resp.get("session") if resp else None
        if not sid:
            print("no hay sesión core todavía (háblale primero a Nyx)", file=sys.stderr)
            return 1
        kitty = shutil.which("kitty")
        if not kitty:
            print(f"kitty no está; abre a mano:  claude --resume {sid}", file=sys.stderr)
            return 1
        subprocess.Popen(
            [kitty, "--title", "nyx · sesión core", "--detach",
             "zsh", "-ic", f"claude --resume {sid}"],
            start_new_session=True,
        )
        print(f"abriendo la sesión core en kitty ({sid[:8]}…)")
        print("ojo: si escribes AHÍ, bifurcas el hilo — Nyx sigue en el suyo")
        return 0
    print("uso: nyx-ctl session [show|new|open]", file=sys.stderr)
    return 1


def _print_reload(resp: dict) -> None:
    applied = resp.get("applied") or []
    restart = resp.get("restart_needed") or []
    if not applied and not restart:
        print("sin cambios")
    if applied:
        print("aplicado en vivo: " + ", ".join(applied))
    if restart:
        print("requiere reinicio: " + ", ".join(restart))


def config_cmd(args: list[str]) -> int:
    sub = args[0] if args else "list"
    if sub == "list":
        flat_eff = nyxconfig.flatten(nyxconfig.load())
        flat_def = nyxconfig.flatten(nyxconfig.DEFAULTS)
        for path in sorted(flat_eff):  # `*` = distinto del default
            mark = "*" if flat_eff[path] != flat_def.get(path) else " "
            print(f"{mark} {path} = {json.dumps(flat_eff[path], ensure_ascii=False)}")
        return 0
    if sub == "get" and len(args) >= 2:
        value = nyxconfig.get_path(nyxconfig.load(), args[1])
        print(json.dumps(value, ensure_ascii=False, indent=2))
        return 0
    if sub == "set" and len(args) >= 3:
        raw = " ".join(args[2:])
        try:
            value = json.loads(raw)  # true/42/"texto"/{...} — JSON primero
        except ValueError:
            value = raw  # fallback: string pelado (nyx-ctl config set voice.edge_voice es-ES-…)
        nyxconfig.update({args[1]: value})
        resp = send({"op": "reload"})
        if resp:
            _print_reload(resp)
        else:
            print("guardado (daemon parado: se aplicará al arrancar)")
        return 0
    print("uso: nyx-ctl config [list | get <ruta> | set <ruta> <valor>]", file=sys.stderr)
    return 1


def main() -> int:
    args = sys.argv[1:]
    cmd = args[0] if args else "status"
    if cmd in ("on", "start"):
        start()
    elif cmd in ("off", "stop"):
        stop()
    elif cmd == "restart":
        restart()
    elif cmd == "install":
        install(notifyd="--notifyd" in args[1:])
    elif cmd == "uninstall":
        uninstall()
    elif cmd == "toggle":
        stop() if daemon_running() else start()
    elif cmd == "status":
        print_status()
    elif cmd == "logs":
        return logs(follow="-f" in args[1:])
    elif cmd == "doctor":
        return doctor()
    elif cmd == "say":
        ok = send({"op": "say", "text": " ".join(args[1:])})
        print("ok" if ok else "daemon no responde (¿nyx-ctl on?)")
    elif cmd == "summon":
        ok = send({"op": "summon"})
        print("ok" if ok else "daemon no responde (¿nyx-ctl on?)")
    elif cmd == "hide":
        ok = send({"op": "hide"})
        print("ok" if ok else "daemon no responde (¿nyx-ctl on?)")
    elif cmd == "ask":
        ok = send({"op": "ask", "text": " ".join(args[1:])})
        print("ok" if ok else "daemon no responde (¿nyx-ctl on?)")
    elif cmd == "tts":
        arg = args[1].lower() if args[1:] else ""
        if arg in ("on", "1", "true", "si", "sí"):
            req = {"op": "tts", "on": True}
        elif arg in ("off", "0", "false", "no"):
            req = {"op": "tts", "on": False}
        else:  # sin argumento (o "toggle") → alterna
            req = {"op": "tts"}
        resp = send(req)
        if resp is None:
            print("daemon no responde (¿nyx-ctl on?)")
        else:  # estado REAL devuelto por el daemon (importa cuando es toggle)
            print("voz ON" if resp.get("tts") else "voz OFF")
    elif cmd == "listen":
        ok = send({"op": "listen"})
        print("ok (toggle escucha)" if ok else "daemon no responde (¿nyx-ctl on?)")
    elif cmd == "listen_stop":
        ok = send({"op": "listen_stop"})
        print("ok" if ok else "daemon no responde (¿nyx-ctl on?)")
    elif cmd == "mood":
        from nyx.theme import MOODS
        arg = (args[1].lower() if args[1:] else "").strip()
        if arg not in MOODS:
            print(f"uso: nyx-ctl mood <{'|'.join(MOODS)}>", file=sys.stderr)
            return 1
        resp = send({"op": "mood", "mood": arg})
        if resp is None:
            print("daemon no responde (¿nyx-ctl on?)")
        else:
            print(f"mood: {resp.get('mood', '?')}")
    elif cmd == "session":
        return session_cmd(args[1:])
    elif cmd == "config":
        return config_cmd(args[1:])
    elif cmd == "reload":
        resp = send({"op": "reload"})
        if resp is None:
            print("daemon no responde (¿nyx-ctl on?)")
        else:
            _print_reload(resp)
    elif cmd == "history":
        ok = send({"op": "history"})
        print("ok (toggle historial)" if ok else "daemon no responde (¿nyx-ctl on?)")
    elif cmd == "panel":
        ok = send({"op": "panel"})
        print("ok (toggle panel de control)" if ok else "daemon no responde (¿nyx-ctl on?)")
    elif cmd == "notify":
        app_name = args[1] if len(args) > 1 else ""
        summary = args[2] if len(args) > 2 else ""
        body = args[3] if len(args) > 3 else ""
        ok = send({"op": "notify", "app": app_name, "summary": summary, "body": body})
        print("ok" if ok else "daemon no responde (¿nyx-ctl on?)")
    elif cmd == "notifs":
        import time as _time
        from nyx.notifqueue import load_recent
        n = int(args[args.index("-n") + 1]) if "-n" in args[1:] else 20
        recs = load_recent(n)
        if not recs:
            print("sin notificaciones registradas")
        for r in recs:
            hhmm = (_time.strftime("%H:%M", _time.localtime(r["ts"]))
                    if r.get("ts") else "--:--")
            mark = "" if r.get("shown", True) else " (silenciada)"
            urg = " ‼" if int(r.get("urgency", 1)) >= 2 else ""
            print(f"{hhmm}  {r.get('app') or 'sistema'} · {r.get('summary', '')}{urg}{mark}")
    elif cmd == "watchers":
        sub = (args[1].lower() if args[1:] else "").strip()
        if sub in ("on", "off") and len(args) >= 3:
            name = args[2]
            nyxconfig.update({f"watchers.{name}.enabled": sub == "on"})
            resp = send({"op": "reload"})
            print(f"watcher {name}: {sub}" + ("" if resp else " (se aplicará al arrancar)"))
        else:
            resp = send({"op": "watchers"})
            if not resp:
                print("daemon parado (nyx-ctl on)")
                return 1
            ws = resp.get("watchers") or {}
            for name, st in ws.items():
                mark = "●" if st.get("running") else ("○" if st.get("enabled") else "·")
                extra = " · ".join(f"{k}={v}" for k, v in st.items()
                                   if k not in ("enabled", "running"))
                print(f" {mark} {name}" + (f" — {extra}" if extra else ""))
            print("(· = off — actívalo con: nyx-ctl watchers on <nombre>)")
    elif cmd == "dnd":
        arg = (args[1].lower() if args[1:] else "").strip()
        if arg in ("on", "off"):
            nyxconfig.update({"notifications.dnd": arg == "on"})
            send({"op": "reload"})
        dnd = nyxconfig.get_path(nyxconfig.load(), "notifications.dnd")
        print("DND activado (solo críticas)" if dnd else "DND apagado")
    elif cmd == "ping":
        print(send({"op": "ping"}))
    else:
        print(
            "uso: nyx-ctl on|off|restart|install [--notifyd]|uninstall"
            "|toggle|status|summon|listen|ask <texto>|say <texto>"
            "|mood <normal|alert|heated|glad|dim>|tts [on|off]|history"
            "|notify <app> <summary> [body]|session [show|new|open]"
            "|config [list|get <ruta>|set <ruta> <valor>]|reload|logs [-f]|doctor|ping",
            file=sys.stderr,
        )
        return 1
    return 0


if __name__ == "__main__":
    sys.exit(main())
